{
  "opencollection": "1.0.0",
  "info": {
    "name": "Vercel AI Gateway API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Models",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Models",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://ai-gateway.vercel.sh/v1/models"
          },
          "docs": "Returns all available AI models accessible through the Vercel AI Gateway. Compatible with the OpenAI models API format."
        }
      ]
    },
    {
      "info": {
        "name": "Chat",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create Chat Completion",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://ai-gateway.vercel.sh/v1/chat/completions",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a chat completion using any model accessible via the Vercel AI Gateway. Supports streaming, tool calls, image inputs, and provider routing options. Compatible with the OpenAI Chat Completions API."
        }
      ]
    },
    {
      "info": {
        "name": "Embeddings",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create Embedding",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://ai-gateway.vercel.sh/v1/embeddings",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create text embeddings using any embedding model accessible via the Vercel AI Gateway. Compatible with the OpenAI Embeddings API."
        }
      ]
    }
  ],
  "bundled": true
}