  "info": {
    "_postman_id": "5945b7cb-d78b-4656-8f8f-57aeb1c37f2a",
    "name": "Vercel v0 Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The v0 Platform API provides programmatic access to v0's AI-powered app generation pipeline. It is a REST interface wrapping v0's full code generation lifecycle from prompt to project to code files to deployment. Capabilities include generating full-stack web apps from natural language prompts, structured parsing of generated code, automatic error fixing, and linking with rendered previews. Requires a v0 API key and a Premium or Team plan.\n\nContact Support:\n Name: Vercel Support",
      "type": "text/plain"
    }
  }
